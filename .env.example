# URL du projet Supabase (Project Settings > API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clé service_role Supabase (Project Settings > API) — NE JAMAIS exposer au client,
# utilisée uniquement dans le code serveur (lib/supabase/server.ts).
SUPABASE_SERVICE_ROLE_KEY=

# Hash bcrypt des deux mots de passe partagés (voir scripts/hash-password.mjs
# pour en générer un). Un membre entre son email + l'un de ces deux mots de
# passe en clair ; le hash correspondant est ce qui est stocké ici.
# ATTENTION : dans un fichier .env* local, Next.js interprète le caractère $
# comme une référence à une autre variable — il faut donc échapper chaque $
# du hash en \$ (ex: \$2b\$12\$...). Sur Vercel (variables saisies dans le
# dashboard), coller le hash brut SANS backslash : cette expansion ne
# s'applique qu'aux fichiers .env* lus localement, pas aux env vars Vercel.
VIEWER_PASSWORD_HASH=
ADMIN_PASSWORD_HASH=

# Secret utilisé pour signer les cookies de session (JWT). Générer une chaîne
# aléatoire longue, ex: openssl rand -base64 32
AUTH_SECRET=

# Protège /api/cron/dca (appelé quotidiennement par Vercel Cron, voir
# vercel.json). Vercel envoie automatiquement ce secret en en-tête
# Authorization pour ses propres appels dès que la variable est définie —
# rien d'autre à configurer côté Vercel. Générer une chaîne aléatoire, ex:
# openssl rand -base64 32
CRON_SECRET=
